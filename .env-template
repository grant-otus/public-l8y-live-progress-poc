# Copy this file to `.env` (same directory) and fill in your Learnosity credentials.
# `.env` is git-ignored; this template is committed. Both are read only by the
# backend signing service — the secret never reaches the frontend.

# Your Learnosity consumer key.
LEARNOSITY_CONSUMER_KEY=your-consumer-key

# Your Learnosity consumer secret (used to sign requests and hash Events API users).
LEARNOSITY_SECRET_KEY=your-consumer-secret

# Port the signing API listens on (the frontend proxy expects 3001).
PORT=3001
